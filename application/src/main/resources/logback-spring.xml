<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ================================================= -->
    <!-- 基本屬性設定 -->
    <!-- ================================================= -->

    <springProperty scope="context"
                    name="APP_NAME"
                    source="spring.application.name"
                    defaultValue="NovaLedger"/>

    <!-- dev/local 純文字 pattern（帶 MDC：traceId, userId, tenantId） -->
    <property name="DEV_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [traceId=%X{traceId:-?} userId=%X{userId:-?} tenantId=%X{tenantId:-?}] %logger{36} - %msg%n"/>

    <!-- ================================================= -->
    <!-- Appenders -->
    <!-- ================================================= -->

    <!-- Console Appender：純文字，dev/local 用 -->
    <appender name="CONSOLE_TEXT"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${DEV_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Console Appender：JSON，prod 用 -->
    <appender name="CONSOLE_JSON"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${APP_NAME}"}</customFields>
        </encoder>
    </appender>

    <!-- ================================================= -->
    <!-- default -->
    <!-- ================================================= -->
    <root level="INFO">
        <appender-ref ref="CONSOLE_TEXT"/>
    </root>

    <!-- ================================================= -->
    <!-- local / dev -->
    <!-- ================================================= -->
    <springProfile name="local,dev">

        <root level="INFO">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>

        <!-- 專案自己的 package 開 DEBUG -->
        <logger name="com.example.novaledger" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE_TEXT"/>
        </logger>

    </springProfile>

    <!-- ================================================= -->
    <!-- test：單元測試 / CI -->
    <!-- ================================================= -->
    <springProfile name="test">

        <root level="WARN">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>

        <logger name="com.example.novaledger" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE_TEXT"/>
        </logger>

    </springProfile>

    <!-- ================================================= -->
    <!-- prod：Railway，輸出 JSON -->
    <!-- ================================================= -->
    <springProfile name="prod">

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>

        <logger name="com.example.novaledger" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE_JSON"/>
        </logger>

        <logger name="org.flywaydb" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE_JSON"/>
        </logger>

    </springProfile>

</configuration>
